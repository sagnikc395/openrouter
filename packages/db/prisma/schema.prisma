// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//Users model
model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  //store the hashed representation of the password
  password           String
  apiKeys            ApiKey[]
  credits            Int                 @default(0)
  onrampTransactions OnrampTransaction[]
  conversations      Conversation[]
}

model ApiKey {
  id            Int            @id @default(autoincrement())
  userId        String
  name          String
  // add encryption in apiKey 
  apiKey        String         @unique
  disabled      Boolean        @default(false)
  user          User           @relation(fields: [userId], references: [id])
  //evey api key has many conversations 
  conversations Conversation[]
  // if user deletes a api key, set it to soft delete 
  deleted       Boolean        @default(false)
}

model Company {
  id      Int     @id @default(autoincrement())
  name    String
  website String
  models  Model[]
}

model Model {
  id                    Int                    @id @default(autoincrement())
  name                  String
  // slug is a human readable slug that we can get and store in the database 
  slug                  String // eg: claude/sonnet4.6 
  companyId             Int
  company               Company                @relation(fields: [companyId], references: [id])
  modelProviderMappings ModelProviderMapping[]
}

model Provider {
  id                    Int                    @id @default(autoincrement())
  name                  String
  website               String
  modelProviderMappings ModelProviderMapping[]
}

model ModelProviderMapping {
  id              Int            @id @default(autoincrement())
  modelId         Int
  providerId      Int
  //cost per million tokens * 1000 
  inputTokenCost  Int
  outputTokenCost Int
  model           Model          @relation(fields: [modelId], references: [id])
  provider        Provider       @relation(fields: [providerId], references: [id])
  conversations   Conversation[]
}

model Conversation {
  // all the conversation the user has been doing 
  // which model was provided and what provider was passed 
  id                     Int                  @id @default(autoincrement())
  userId                 String
  apiKeyId               Int
  modelProviderMappingId Int
  input                  String
  output                 String
  inputTokenCount        Int
  outputTokenCount       Int
  user                   User                 @relation(fields: [userId], references: [id])
  apiKey                 ApiKey               @relation(fields: [apiKeyId], references: [id])
  modelProviderMapping   ModelProviderMapping @relation(fields: [modelProviderMappingId], references: [id])
}

model OnrampTransaction {
  //when user pays some amount , add with the payment gateway
  id     Int    @id @default(autoincrement())
  userId String
  amount Int
  status String
  user   User   @relation(fields: [userId], references: [id])
}
