generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  password           String
  // not usd value -> 1 $ = 100credits 
  credits            Int                 @default(1000)
  apiKeys            ApiKey[]
  onrampTransactions OnrampTransaction[]
  conversations      Conversation[]
}

model ApiKey {
  id              Int            @id @default(autoincrement())
  userId          Int
  name            String
  //apiKey shouldnt be placed as plain text in the db , should be encrypted
  apiKey          String         @unique
  disabled        Boolean        @default(false)
  //soft delete the deleted flag so that it doesnt break FK relationship
  deleted         Boolean        @default(false)
  lastUsed        DateTime?
  creditsConsumed Int            @default(0)
  user            User           @relation(fields: [userId], references: [id])
  conversations   Conversation[]
}

model Company {
  id      Int     @id @default(autoincrement())
  name    String
  website String
  models  Model[]
}

model Model {
  id                    Int                    @id @default(autoincrement())
  name                  String
  // slug is the name of the company name + model name 
  // moonshot-ai/Kimi-K2
  // human readable slug that the model provides us 
  slug                  String
  companyId             Int
  company               Company                @relation(fields: [companyId], references: [id])
  modelProviderMappings ModelProviderMapping[]
}

model Provider {
  id                    Int                    @id @default(autoincrement())
  name                  String
  website               String
  // models and providers exist indep and is a many to many relationship in the providers
  modelProviderMappings ModelProviderMapping[]
}

model ModelProviderMapping {
  // create a many to many relationship mapping 
  id              Int            @id @default(autoincrement())
  modelId         Int
  providerId      Int
  // actually cost per million tokens, not a good idea to store floats in database 
  // even if we have to pad the cost a bit 
  // the credits that the user has should be an integer.
  inputTokenCost  Int
  outputTokenCost Int
  model           Model          @relation(fields: [modelId], references: [id])
  provider        Provider       @relation(fields: [providerId], references: [id])
  conversations   Conversation[]
}

model OnrampTransaction {
  id     Int    @id @default(autoincrement())
  userId Int
  amount Int
  status String
  user   User   @relation(fields: [userId], references: [id])
}

model Conversation {
  id                     Int                  @id @default(autoincrement())
  userId                 Int
  apiKeyId               Int
  modelProviderMappingId Int
  input                  String
  output                 String
  inputTokenCount        Int
  outputTokenCount       Int
  user                   User                 @relation(fields: [userId], references: [id])
  apiKey                 ApiKey               @relation(fields: [apiKeyId], references: [id])
  modelProviderMapping   ModelProviderMapping @relation(fields: [modelProviderMappingId], references: [id])
}
